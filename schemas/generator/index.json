{
  "title": "Generation Schema",
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "name": {
      "type": "string",
      "description": "Application name"
    },
    "description": {
      "type": "string",
      "description": "Application description"
    },
    "entities": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "object",
          "oneOf": [
            {
              "$ref": "#/definitions/Referance"
            },
            {
              "$ref": "#/definitions/Entity"
            }
          ]
        },
        "additionalProperties": false
      }
    },
    "views": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "$ref": "#/definitions/ViewProperty"
        }
      }
    },

    "commons": {
      "type": "object",
      "$ref": "#/properties/entities"
    }
  },
  "definitions": {
    "Referance": {
      "title": "Referance",
      "type": "object",
      "patternProperties": {
        "^\\$ref$": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Entity": {
      "title": "Entity defination",
      "type": "object",
      "properties": {
        "properties": {
          "patternProperties": {
            ".*": {
              "type": "object",
              "oneOf": [
                {
                  "$ref": "#/definitions/StringProperty"
                },
                {
                  "$ref": "#/definitions/NumberProperty"
                },
                {
                  "$ref": "#/definitions/DateProperty"
                },
                {
                  "$ref": "#/definitions/BooleanProperty"
                },
                {
                  "$ref": "#/definitions/RelationProperty"
                }
              ]
            }
          }
        },
        "mainProperty": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unique": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": ["properties", "mainProperty", "required"]
    },
    "InputFormat": {
      "type": "string",
      "enum": [
        "string",
        "boolean",
        "date",
        "password",
        "email",
        "phone",
        "id",
        "uuid",
        "number"
      ]
    },

    "StringProperty": {
      "title": "String Property",
      "type": "object",
      "properties": {
        "type": {
          "const": "string"
        },
        "inputType": {
          "$ref": "#/definitions/InputType",
          "default": "text"
        },
        "format": {
          "$ref": "#/definitions/InputFormat"
        },
        "minLength": { "type": "number", "default": 1 },
        "maxLength": { "type": "number", "default": 30 },
        "ean": { "type": "boolean", "const": true },
        "email": { "type": "boolean", "const": true },
        "uuid": { "type": "boolean", "const": true },
        "password": { "type": "boolean", "const": true },
        "enum": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false,
      "required": ["type", "minLength", "maxLength", "inputType"]
    },
    "NumberProperty": {
      "title": "Number Property",
      "type": "object",
      "properties": {
        "type": {
          "const": "number"
        },
        "inputType": {
          "$ref": "#/definitions/InputType",
          "default": "number"
        },
        "min": { "type": "number", "default": 0 },
        "max": { "type": "number", "default": 900900900900 },
        "format": { "$ref": "#/definitions/InputFormat" }
      },
      "additionalProperties": false,
      "required": ["type", "min", "max", "inputType"]
    },
    "DateProperty": {
      "title": "Date Property",
      "type": "object",
      "properties": {
        "type": {
          "const": "date"
        },
        "inputType": {
          "$ref": "#/definitions/InputType",
          "default": "date"
        },
        "timestamp": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "deletedAt", "custom"],
          "default": "id"
        },
        "format": { "$ref": "#/definitions/InputFormat" }
      },
      "additionalProperties": false,
      "required": ["type", "format", "inputType"]
    },
    "BooleanProperty": {
      "title": "Boolean Property",
      "type": "object",
      "properties": {
        "type": {
          "const": "boolean"
        },
        "inputType": {
          "$ref": "#/definitions/InputType",
          "default": "checkbox"
        },
        "format": { "$ref": "#/definitions/InputFormat" }
      },
      "additionalProperties": false,
      "required": ["type", "inputType"]
    },
    "InputType": {
      "type": "string",
      "enum": [
        "text",
        "textarea",
        "checkbox",
        "select-one",
        "select-many",
        "search-one",
        "search-many",
        "date",
        "currency",
        "email",
        "password",
        "barcode",
        "number",
        "phone"
      ],
      "additionalProperties": false
    },
    "RelationProperty": {
      "title": "Relation Property",
      "type": "object",
      "properties": {
        "type": {
          "enum": ["many-to-one", "many-to-many", "one-to-one", "one-to-many"],
          "default": "many-to-one",
          "description": "Type of the relation ship"
        },
        "inputType": {
          "$ref": "#/definitions/InputType",
          "default": "search-one"
        },
        "target": {
          "$ref": "#/definitions/ResourceNames"
        },
        "views": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "properties": {
                "as": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "date", "boolean"],
                  "default": "string"
                }
              },
              "additionalProperties": false,
              "required": ["as", "type"]
            }
          }
        },
        "format": { "$ref": "#/definitions/InputFormat" }
      },
      "additionalProperties": false,
      "required": ["type", "target", "views", "inputType"]
    },
    "Select": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "properties": {
            "as": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": ["string", "number", "date", "boolean"]
            }
          },
          "additionalProperties": false
        }
      }
    },
    "ViewProperty": {
      "title": "View Property",
      "type": "object",
      "properties": {
        "from": {
          "description": "Main entity",
          "$ref": "#/definitions/ResourceNames"
        },
        "select": {
          "$ref": "#/definitions/Select"
        },
        "join": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "properties": {
                "select": {
                  "$ref": "#/definitions/Select"
                }
              }
            }
          }
        }
      },
      "additionalProperties": false,
      "required": ["from", "join"]
    },
    "ResourceNames": {
      "title": "Resource Names",
      "type": "string",
      "description": "Target entity for this relation.",
      "enum": [
        "product",
        "store",
        "price",
        "quantity",
        "category",
        "pricelevel",
        "user",
        "customer",
        "permission",
        "cart",
        "order",
        "saleunit",
        "sale",
        "transaction",
        "project",
        "sprint",
        "tag",
        "blog",
        "task"
      ],
      "default": "category"
    }
  },
  "additionalProperties": false
}
