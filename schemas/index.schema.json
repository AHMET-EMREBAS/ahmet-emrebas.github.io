{
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "properties": {
      "patternProperties": {
        ".*": {
          "$ref": "#/definitions/PropertyTypes"
        }
      },
      "propertyNames": {
        "$ref": "#/definitions/PropertyNames"
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "relations": {
      "patternProperties": {
        ".*": {
          "$ref": "./relation.schema.json"
        }
      }
    },
    "required": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PropertyNames"
      }
    },
    "unique": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PropertyNames"
      }
    },
    "urlParam": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PropertyNames"
      }
    },
    "urlQuery": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PropertyNames"
      }
    },
    "generated": {
      "description": "Properties genereated by backend",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "static": {
      "description": "Static properties that not allowed to update.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/definitions/PropertyNames"
      }
    },
    "formGroup": {
      "patternProperties": {
        ".*": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PropertyNames"
          }
        }
      }
    },
    "sortables": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "searchable": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  },
  "definitions": {
    "PropertyNames": {
      "$ref": "./property-names.schema.json"
    },
    "PropertyTypes": {
      "$ref": "./property-type.schema.json"
    }
  },
  "additionalProperties": false
}
