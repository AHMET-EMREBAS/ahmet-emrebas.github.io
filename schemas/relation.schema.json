{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "RelationTypes",
  "title": "Relation Types",
  "properties": {
    "type": {
      "enum": ["ManyToMany", "OneToMany", "OneToOne", "ManyToOne"]
    },
    "target": {
      "type": "string"
    },
    "onDelete": {
      "enum": ["RESTRICT", "CASCADE", "SET NULL", "DEFAULT", "NO ACTION"]
    },
    "onUpdate": {
      "enum": ["RESTRICT", "CASCADE", "SET NULL", "DEFAULT", "NO ACTION"]
    },
    "eager": {
      "type": "boolean"
    },
    "views": {
      "patternProperties": {
        ".*": {
          "properties": {
            "as": {
              "type": "string"
            },
            "prefix": {
              "type": "string"
            },
            "suffix": {
              "type": "string"
            },
            "label": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "propertyNames": {
        "$ref": "./property-names.schema.json"
      }
    }
  },
  "additionalProperties": false
}
