{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Property",
  "$id": "Property",
  "propertyNames": {
    "$ref": "../name/property.schema.json"
  },
  "minProperties": 1,
  "patternProperties": {
    ".*": {
      "oneOf": [
        { "$ref": "./currency.schema.json" },
        { "$ref": "./description.schema.json" },
        { "$ref": "./email.schema.json" },
        { "$ref": "./integer.schema.json" },
        { "$ref": "./name.schema.json" },
        { "$ref": "./number.schema.json" },
        { "$ref": "./password.schema.json" },
        { "$ref": "./string.schema.json" },
        { "$ref": "./uuid.schema.json" },
        { "$ref": "./ean.schema.json" }
      ]
    }
  }
}
