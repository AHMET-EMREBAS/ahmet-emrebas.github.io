{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Http Get",
  "type": "object",
  "patternProperties": {
    ".*": {
      "properties": {
        "description": { "type": "string" },
        "params": {
          "patternProperties": {
            ".*": {
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "date", "boolean"]
                },
                "description": {
                  "type": "string"
                },
                "required": {
                  "type": "boolean",
                  "default": true
                },
                "default": {},
                "minLength": {
                  "type": "number"
                },
                "maxLength": {
                  "type": "number"
                },
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                },
                "in": {
                  "enum": ["query", "param"]
                }
              },
              "additionalProperties": false,
              "required": ["type", "in"]
            }
          }
        }
      },
      "minItems": 1,
      "additionalProperties": false
    }
  }
}
