{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Basic Resource",
  "properties": {
    "type": {
      "const": "basic-resource"
    },
    "properties": {
      "$ref": "./properties.json"
    },
    "required": {
      "type": "array",
      "description": "List of required items",
      "items": {
        "type": "string"
      }
    },
    "unique": {
      "type": "array",
      "description": "List of unique items",
      "items": {
        "type": "string"
      }
    },
    "group": {
      "type": "object",
      "description": "Group input items. Each group will be shown in the same form.",
      "patternProperties": {
        "^[a-z]{1}[a-zA-Z]{1,}$": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "mainProperty": {
      "type": "string",
      "description": "The readable and desdriptive property of the entity to represent the entity as text.",
      "default": "name"
    },
    "rest": {
      "type": "object",
      "$ref": "../rest/index.json"
    }
  },
  "required": ["type", "mainProperty"],
  "additionalProperties": false
}
