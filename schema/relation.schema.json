{
  "$schema": "http://json-schema.org/draft-07/schema",
  "oneOf": [
    { "$ref": "#/definitions/ManyToMany" },
    { "$ref": "#/definitions/ManyToOne" },
    { "$ref": "#/definitions/OneToMany" },
    { "$ref": "#/definitions/OneToOne" }
  ],
  "definitions": {
    "RelationOptions": {
      "properties": {
        "cascade": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "type": "array",
              "items": {
                "enum": ["insert", "update", "remove", "soft-remove", "recover"]
              }
            }
          ],
          "default": true
        },
        "nullable": {
          "type": "boolean",
          "default": true
        },
        "eager": {
          "type": "boolean",
          "default": true
        },
        "onDelete": {
          "enum": ["RESTRICT", "CASCADE", "SET NULL", "DEFAULT", "NO ACTION"],
          "default": "SET NULL"
        },
        "onUpdate": {
          "enum": ["RESTRICT", "CASCADE", "SET NULL", "DEFAULT", "NO ACTION"],
          "default": "SET NULL"
        },
        "deferrable": {
          "enum": ["INITIALLY IMMEDIATE", "INITIALLY DEFERRED"]
        },
        "createForeignKeyConstraints": {
          "type": "boolean",
          "default": true
        },
        "lazy": {
          "type": "boolean",
          "default": true
        },
        "orphanedRowAction": {
          "enum": ["nullify", "delete", "soft-delete", "disable"],
          "default": "nullify"
        }
      }
    },

    "ManyToMany": {
      "properties": {
        "type": {
          "const": "ManyToMany"
        },

        "target": {
          "$ref": "./resource-names.schema.json"
        },
        "join": {
          "type": "boolean"
        },
        "options": {
          "$ref": "#/definitions/RelationOptions"
        }
      },
      "additionalProperties": false,
      "required": ["type", "target"]
    },
    "ManyToOne": {
      "properties": {
        "type": {
          "const": "ManyToOne"
        },
        "target": {
          "$ref": "./resource-names.schema.json"
        },
        "join": {
          "type": "boolean"
        },
        "options": {
          "$ref": "#/definitions/RelationOptions"
        }
      },
      "additionalProperties": false,
      "required": ["type", "target"]
    },
    "OneToMany": {
      "properties": {
        "type": {
          "const": "OneToMany"
        },
        "target": {
          "$ref": "./resource-names.schema.json"
        },
        "join": {
          "type": "boolean"
        },
        "options": {
          "$ref": "#/definitions/RelationOptions"
        }
      },
      "additionalProperties": false,
      "required": ["type", "target"]
    },
    "OneToOne": {
      "properties": {
        "type": {
          "const": "OneToOne"
        },
        "target": {
          "$ref": "./resource-names.schema.json"
        },
        "join": {
          "type": "boolean"
        },
        "options": {
          "$ref": "#/definitions/RelationOptions"
        }
      },
      "additionalProperties": false,
      "required": ["type", "target"]
    }
  }
}
