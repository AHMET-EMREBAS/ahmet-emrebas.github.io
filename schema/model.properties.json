{
  "$schema": "http://json-schema.org/draft-07/schema",
  "patternProperties": {
    ".*": {
      "oneOf": [
        { "$ref": "#/definitions/String" },
        { "$ref": "#/definitions/Number" },
        { "$ref": "#/definitions/Date" },
        { "$ref": "#/definitions/Currency" }
      ]
    }
  },
  "minItems": 1,
  "definitions": {
    "String": {
      "properties": {
        "type": { "type": "string", "const": "string" },
        "inputType": { "type": "string", "enum": ["text", "textarea"] },
        "minLength": { "type": "number" },
        "maxLength": { "type": "number" }
      },
      "required": ["type", "inputType", "minLength", "maxLength"],
      "additionalProperties": false
    },
    "Number": {
      "properties": {
        "type": { "type": "string", "const": "number" },
        "inputType": { "type": "string", "const": "number" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      },
      "required": ["type", "inputType", "minimum", "maximum"],
      "additionalProperties": false
    },
    "Currency": {
      "properties": {
        "type": { "type": "string", "const": "currency" },
        "inputType": { "type": "string", "const": "currency" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      },
      "required": ["type", "inputType", "minimum", "maximum"],
      "additionalProperties": false
    },
    "Date": {
      "properties": {
        "type": { "type": "string", "const": "date" },
        "inputType": { "type": "string", "const": "date" },
        "future": { "type": "boolean" },
        "past": { "type": "boolean" }
      },
      "required": ["type", "inputType"],
      "additionalProperties": false
    }
  }
}
