{
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "target": {
      "$ref": "./resource-names.schema.json"
    },
    "parent": {
      "$ref": "./resource-names.schema.json"
    },
    "viewFields": {
      "patternProperties": {
        ".*": {
          "properties": {
            "type": { "enum": ["string", "number", "boolean", "Date"] }
          },
          "additionalProperties": false
        }
      }
    },
    "condition": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": ["target", "parent"]
}
