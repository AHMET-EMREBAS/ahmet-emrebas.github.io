{
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "properties": {
      "patternProperties": {
        ".*": {
          "$ref": "./property.schema.json"
        }
      }
    },
    "relations": {
      "patternProperties": {
        ".*": {
          "$ref": "./relation.schema.json"
        }
      }
    },
    "views": {
      "type": "array",
      "items": {
        "$ref": "./relation-view.schema.json"
      }
    }
  },
  "additionalProperties": false
}
