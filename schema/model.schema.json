{
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "properties": {
      "propertyNames": {
        "$ref": "./property-names.schema.json"
      },
      "minProperties": 1,
      "patternProperties": {
        ".*": {
          "additionalProperties": false,
          "properties": {
            "type": { "$ref": "#/definitions/ColumnType" },
            "prefix": { "type": "string" },
            "suffix": { "type": "string" },
            "icon": { "type": "string" },
            "inputType": {
              "oneOf": [
                {
                  "if": { "properties": { "type": { "const": "text" } } },
                  "then": { "$ref": "#/definitions/TextInput" }
                },
                {
                  "if": { "properties": { "type": { "const": "numeric" } } },
                  "then": { "$ref": "#/definitions/NumberInput" }
                },
                {
                  "if": { "properties": { "type": { "const": "boolean" } } },
                  "then": { "$ref": "#/definitions/BooleanInput" }
                },
                {
                  "if": { "properties": { "type": { "const": "date" } } },
                  "then": { "$ref": "#/definitions/DateInput" }
                }
              ]
            },
            "default": {
              "oneOf": [
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            },
            "minLenght": {
              "type": "number",
              "default": 0
            },
            "maxLength": {
              "type": "number",
              "default": 0
            },
            "minimum": {
              "type": "number",
              "default": 0
            },
            "maximum": {
              "type": "number",
              "default": 0
            },
            "email": {
              "type": "boolean",
              "default": true
            },
            "password": {
              "type": "boolean",
              "default": true
            },
            "uuid": {
              "type": "boolean",
              "default": true
            }
          }
        }
      }
    },
    "relations": {
      "title": "Relations",
      "propertyNames": {
        "$ref": "./property-names.schema.json"
      },
      "minProperties": 1,
      "patternProperties": {
        ".*": {
          "additionalProperties": false,
          "properties": {
            "view": {
              "patternProperties": {
                ".*": {
                  "properties": {
                    "as": {
                      "type": "string"
                    },
                    "prefix": { "type": "string" },
                    "suffix": { "type": "string" }
                  }
                }
              },
              "propertyNames": {
                "$ref": "./property-names.schema.json"
              }
            },
            "type": {
              "$ref": "#/definitions/RelationType"
            },
            "icon": {
              "type": "string"
            },
            "inputType": {
              "$ref": "#/definitions/RelationInput"
            },
            "target": {
              "$ref": "./resource-names.schema.json"
            },
            "nullable": {
              "type": "boolean",
              "default": true
            },
            "eager": { "type": "boolean", "default": true },
            "cascade": {
              "type": "array",
              "items": {
                "enum": ["insert", "update", "remove", "soft-remove", "recover"]
              }
            },
            "onDelete": {
              "enum": [
                "RESTRICT",
                "CASCADE",
                "SET NULL",
                "DEFAULT",
                "NO ACTION"
              ]
            },
            "onUpdate": {
              "enum": [
                "RESTRICT",
                "CASCADE",
                "SET NULL",
                "DEFAULT",
                "NO ACTION"
              ]
            }
          }
        }
      }
    },
    "required": {
      "type": "array",
      "description": "Required properties",
      "items": {
        "$ref": "./property-names.schema.json"
      },
      "uniqueItems": true
    },
    "unique": {
      "type": "array",
      "description": "Unique properties",
      "items": {
        "$ref": "./property-names.schema.json"
      },
      "uniqueItems": true
    },
    "static": {
      "type": "array",
      "description": "Properties that not allowed to update.",
      "items": {
        "$ref": "./property-names.schema.json"
      },
      "uniqueItems": true
    }
  },
  "definitions": {
    "ColumnType": {
      "enum": ["text", "numeric", "integer", "boolean", "date"]
    },
    "RelationType": {
      "enum": ["many-to-many", "one-to-many", "one-to-one", "many-to-one"]
    },
    "TextInput": {
      "$id": "TextInput",
      "enum": [
        "text",
        "textarea",
        "texteditor",
        "password",
        "email",
        "upc",
        "phone"
      ]
    },
    "NumberInput": {
      "$id": "NumberInput",
      "enum": ["number", "integer", "currency"]
    },
    "BooleanInput": {
      "$id": "BooleanInput",
      "enum": ["checkbox", "switch"]
    },
    "DateInput": {
      "$id": "DateInput",
      "enum": ["date", "time", "date-time"]
    },
    "RelationInput": {
      "$id": "RelationInput",
      "enum": [
        "select-one",
        "select-many",
        "find-one",
        "find-many",
        "checkbox-group",
        "radio-group"
      ]
    }
  }
}
