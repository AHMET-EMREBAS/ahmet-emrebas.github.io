{
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "meta": {
      "properties": {
        "type": {
          "const": "number"
        }
      }
    },
    "validators": {
      "properties": {
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        }
      }
    },
    "ui": {
      "properties": {
        "component": {
          "const": "number"
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
