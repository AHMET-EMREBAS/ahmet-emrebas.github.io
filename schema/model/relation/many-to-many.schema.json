{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "ManyToMany Property",
  "$id": "ManyToManyProperty",
  "properties": {
    "description": { "type": "string" },
    "type": { "const": "ManyToMany" },
    "target": { "type": "string", "$ref": "../name/resource.schema.json" },
    "inputType": {
      "enum": [
        "select-many",
        "find-many",
        "checkbox-group",
        "switch-group",
        "NA"
      ]
    },
    "viewColumns": {
      "patternProperties": {
        ".*": { "properties": { "as": { "type": "string" } } }
      },
      "propertyNames": { "$ref": "../name/property.schema.json" },
      "minProperties": 1
    },
    "eager": { "type": "boolean", "default": true },
    "nullable": { "type": "boolean", "default": true },
    "onDelete": {
      "enum": ["RESTRICT", "CASCADE", "SET NULL", "DEFAULT", "NO ACTION"],
      "default": "CASCADE"
    },
    "onUpdate": {
      "enum": ["RESTRICT", "CASCADE", "SET NULL", "DEFAULT", "NO ACTION"],
      "default": "CASCADE"
    },
    "cascase": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["insert", "update", "remove", "soft-remove", "recover"]
      }
    }
  },
  "required": ["type", "target", "inputType"],
  "additionalProperties": false
}
