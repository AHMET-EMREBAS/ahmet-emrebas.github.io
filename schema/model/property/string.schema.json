{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "String Property",
  "$id": "StringProperty",
  "properties": {
    "description": { "type": "string" },
    "type": { "const": "String" },
    "inputType": {
      "enum": [
        "text",
        "texteditor",
        "password",
        "email",
        "uuid",
        "barcode",
        "textarea",
        "select-one",
        "select-many",
        "NA"
      ]
    },
    "enum": { "type": "array", "items": {} },
    "generated": { "type": "string", "enum": ["id", "uuid"] },
    "name": { "type": "boolean", "description": "Validator", "default": true },
    "required": {
      "type": "boolean",
      "description": "Validator",
      "default": true
    },
    "unique": {
      "type": "boolean",
      "description": "Validator",
      "default": true
    },
    "minLength": { "type": "number", "description": "Validator", "default": 0 },
    "maxLength": { "type": "number", "description": "Validator", "default": 0 },
    "email": { "type": "boolean", "description": "Validator", "default": true },
    "password": {
      "type": "boolean",
      "description": "Validator",
      "default": true
    },
    "uuid": { "type": "boolean", "description": "Validator", "default": true },
    "barcode": {
      "type": "boolean",
      "description": "Validator",
      "default": true
    },
    "phone": { "type": "boolean", "description": "Validator", "default": true }
  },
  "required": ["type", "inputType"],
  "additionalProperties": false
}
