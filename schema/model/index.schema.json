{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "ModelSchema",
  "properties": {
    "properties": {
      "patternProperties": {
        ".*": {
          "properties": {
            "type": {
              "$ref": "#/definitions/PropertyTypes"
            },
            "minLength": { "type": "number", "minimum": 0 },
            "maxLength": { "type": "number", "minimum": 0 },
            "minimum": { "type": "number", "minimum": 0 },
            "maximum": { "type": "number", "minimum": 0 },
            "isEmail": { "type": "boolean" },
            "isPassword": { "type": "boolean" },
            "isUUID": { "type": "boolean" },
            "isUnique": { "type": "boolean" }
          },
          "required": ["type"],
          "additionalProperties": false
        }
      }
    },
    "relations": {
      "patternProperties": {
        ".*": {
          "properties": {
            "type": {
              "enum": ["ManyToMany", "OneToOne", "OneToMany", "ManyToOne"]
            },
            "target": {
              "$ref": "#/definitions/ResourceNames"
            },
            "targetProperty": {
              "type": "string"
            },
            "join": {
              "type": "boolean"
            },
            "views": {
              "patternProperties": {
                ".*": {
                  "properties": {
                    "as": { "type": "string" }
                  },
                  "required": ["as"],
                  "additionalProperties": false
                }
              }
            }
          },
          "required": ["type", "target", "views"],
          "additionalProperties": false
        }
      }
    }
  },
  "definitions": {
    "PropertyTypes": {
      "enum": ["string", "number", "integer", "date", "boolean"]
    },
    "ResourceNames": {
      "enum": [
        "Product",
        "Category",
        "Price",
        "PriceLevel",
        "Quantity",
        "Store",
        "User",
        "Customer",
        "Porder"
      ]
    }
  }
}
