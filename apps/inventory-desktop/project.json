{
  "name": "inventory-desktop",
  "sourceRoot": "apps/inventory-desktop/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx-electron:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/inventory-desktop",
        "main": "apps/inventory-desktop/src/main.ts",
        "tsConfig": "apps/inventory-desktop/tsconfig.app.json",
        "assets": ["apps/inventory-desktop/src/assets"]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/inventory-desktop/src/environments/environment.ts",
              "with": "apps/inventory-desktop/src/environments/environment.prod.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "executor": "nx-electron:execute",
      "options": {
        "buildTarget": "inventory-desktop:build"
      }
    },
    "package": {
      "executor": "nx-electron:package",
      "options": {
        "name": "inventory-desktop",
        "frontendProject": "inventory",
        "outputPath": "dist/packages/inventory-desktop",
        "prepackageOnly": true
      }
    },
    "make": {
      "executor": "nx-electron:make",
      "options": {
        "name": "inventory-desktop",
        "frontendProject": "inventory",
        "outputPath": "dist/executables/inventory-desktop"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/inventory-desktop/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["coverage/apps/inventory-desktop"],
      "options": {
        "jestConfig": "apps/inventory-desktop/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
