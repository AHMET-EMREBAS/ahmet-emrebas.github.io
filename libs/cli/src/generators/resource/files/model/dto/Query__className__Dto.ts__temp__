import { WhereQueryField } from '@ae/core';
import { InputType } from '@nestjs/graphql';
import { FindOperator } from 'typeorm';

@InputType()
export class Query<%- className %>Dto {


  <% entity.properties.forEach(e=>{ %>

  @WhereQueryField()
  <%- genName(e.name).propertyName %>?: FindOperator<any>;

  <% }) %>
}
